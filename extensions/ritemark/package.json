{
  "name": "ritemark",
  "displayName": "RiteMark Editor",
  "description": "WYSIWYG Markdown Editor",
  "version": "0.1.0",
  "publisher": "ritemark",
  "license": "MIT",
  "engines": {
    "vscode": "^1.94.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "ritemark.configureApiKey",
        "title": "RiteMark: Configure OpenAI API Key"
      },
      {
        "command": "ritemark.showAIPanel",
        "title": "RiteMark: Show AI Assistant",
        "icon": "$(sparkle)"
      },
      {
        "command": "ritemark.openSearch",
        "title": "Search",
        "icon": "$(search)"
      }
    ],
    "viewsContainers": {
      "auxiliarybar": [
        {
          "id": "ritemark-ai",
          "title": "AI Assistant",
          "icon": "$(sparkle)"
        }
      ]
    },
    "views": {
      "ritemark-ai": [
        {
          "type": "webview",
          "id": "ritemark.aiView",
          "name": "AI Assistant",
          "contextualTitle": "RiteMark AI",
          "visibility": "visible"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "ritemark.showAIPanel",
          "group": "navigation",
          "when": "activeCustomEditorId == ritemark.editor"
        }
      ],
      "view/title": [
        {
          "command": "ritemark.openSearch",
          "when": "view == workbench.explorer.fileView",
          "group": "navigation@1"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "ritemark.editor",
        "displayName": "RiteMark",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          }
        ],
        "priority": "default"
      }
    ],
    "configurationDefaults": {
      "workbench.sideBar.location": "left",
      "workbench.colorTheme": "Default Light Modern",
      "workbench.activityBar.location": "default",
      "extensions.ignoreRecommendations": true,
      "workbench.tips.enabled": false,
      "debug.showInStatusBar": "never",
      "testing.openTesting": "neverOpen",
      "outline.showVariables": false,
      "outline.showFunctions": false,
      "timeline.showUncommittedChanges": false
    },
    "walkthroughs": [
      {
        "id": "ritemark.welcome",
        "title": "Get Started with RiteMark",
        "description": "Your AI-powered markdown editor for focused writing",
        "steps": [
          {
            "id": "welcome",
            "title": "Welcome to RiteMark",
            "description": "RiteMark is a distraction-free markdown editor with built-in AI assistance.\n\nWrite beautiful documents with a clean WYSIWYG interface while AI helps you improve your writing.",
            "media": {
              "altText": "RiteMark Editor",
              "svg": "media/icon.svg"
            },
            "completionEvents": [
              "onStepSelected"
            ]
          },
          {
            "id": "configureApiKey",
            "title": "Configure AI API Key",
            "description": "To use AI features, you'll need an OpenAI API key.\n\nGet your key from [OpenAI](https://platform.openai.com/api-keys).\n\nYour key is stored securely in your system keychain.\n\n[Configure API Key](command:ritemark.configureApiKey)",
            "media": {
              "altText": "API Key Setup",
              "svg": "media/icon.svg"
            },
            "completionEvents": [
              "onCommand:ritemark.configureApiKey"
            ]
          },
          {
            "id": "openMarkdown",
            "title": "Open a Markdown File",
            "description": "Open any `.md` or `.markdown` file to start editing with RiteMark's WYSIWYG editor.\n\n[Open File](command:workbench.action.files.openFile)\n\nOr create a new file and save it with a `.md` extension.",
            "media": {
              "altText": "Open Markdown",
              "svg": "media/icon.svg"
            },
            "completionEvents": [
              "onCommand:workbench.action.files.openFile"
            ]
          },
          {
            "id": "tryAI",
            "title": "Try AI Features",
            "description": "Select some text in your document, then use the AI panel to:\n\n- **Rephrase** - Improve your writing style\n- **Find & Replace** - Smart text transformations\n- **Insert** - Add new content\n\n[Show AI Panel](command:ritemark.showAIPanel)",
            "media": {
              "altText": "AI Features",
              "svg": "media/icon.svg"
            },
            "completionEvents": [
              "onCommand:ritemark.showAIPanel"
            ]
          }
        ]
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "openai": "^4.73.0",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/turndown": "^5.0.5",
    "@types/vscode": "^1.94.0",
    "lucide-static": "^0.555.0",
    "typescript": "^5.0.0"
  }
}
