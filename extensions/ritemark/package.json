{
  "name": "ritemark",
  "displayName": "Ritemark Editor",
  "description": "WYSIWYG Markdown Editor",
  "version": "1.4.0",
  "publisher": "ritemark",
  "license": "MIT",
  "engines": {
    "vscode": "^1.94.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onCustomEditor:ritemark.editor",
    "onCustomEditor:ritemark.excelViewer",
    "onView:ritemark.unifiedView",
    "onCommand:ritemark.configureApiKey",
    "onCommand:ritemark.showAIPanel",
    "onCommand:ritemark.openSearch",
    "onCustomEditor:ritemark.flowEditor",
    "onView:ritemark.flowsView",
    "onCustomEditor:ritemark.pdfViewer",
    "onCustomEditor:ritemark.docxViewer"
  ],
  "contributes": {
    "commands": [
      {
        "command": "ritemark.configureApiKey",
        "title": "Ritemark: Configure OpenAI API Key"
      },
      {
        "command": "ritemark.showAIPanel",
        "title": "Ritemark: Show AI Assistant",
        "icon": "$(sparkle)"
      },
      {
        "command": "ritemark.openSearch",
        "title": "Search",
        "icon": "$(search)"
      },
      {
        "command": "ritemark.reindexDocuments",
        "title": "Ritemark: Re-index Documents"
      },
      {
        "command": "ritemark.newChat",
        "title": "New Chat",
        "icon": "$(add)"
      },
      {
        "command": "ritemark.aiSettings",
        "title": "AI Settings",
        "icon": "$(gear)"
      },
      {
        "command": "ritemark.chatHistory",
        "title": "Chat History",
        "icon": "$(history)"
      },
      {
        "command": "ritemark.flows.new",
        "title": "New Flow",
        "icon": "$(add)"
      },
      {
        "command": "ritemark.flows.refresh",
        "title": "Refresh Flows",
        "icon": "$(refresh)"
      },
      {
        "command": "ritemark.flows.settings",
        "title": "Flow Settings",
        "icon": "$(gear)"
      }
    ],
    "configuration": [
      {
        "title": "Ritemark Updates",
        "properties": {
          "ritemark.updates.enabled": {
            "type": "boolean",
            "default": true,
            "description": "Check for updates on startup"
          },
          "ritemark.updates.dismissed": {
            "type": "string",
            "default": "",
            "description": "Last dismissed update version (internal)"
          }
        }
      },
      {
        "title": "Ritemark Features",
        "properties": {
          "ritemark.features.voice-dictation": {
            "type": "boolean",
            "default": false,
            "description": "Enable voice dictation (experimental, macOS only). Requires Whisper model download (~75MB).",
            "scope": "application"
          },
          "ritemark.features.agentic-assistant": {
            "type": "boolean",
            "default": false,
            "description": "Enable Claude Code agent in the AI sidebar (experimental). Allows autonomous file operations.",
            "scope": "application"
          }
        }
      },
      {
        "title": "Ritemark AI",
        "properties": {
          "ritemark.ai.selectedAgent": {
            "type": "string",
            "default": "ritemark-agent",
            "enum": [
              "ritemark-agent",
              "claude-code"
            ],
            "enumDescriptions": [
              "Ritemark Agent - Chat assistant with RAG search and image generation",
              "Claude Code (experimental) - Autonomous agent that can read, write, and organize files"
            ],
            "description": "Select which AI agent to use in the sidebar",
            "scope": "application"
          },
          "ritemark.ai.excludedFolders": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              ".git",
              "node_modules",
              ".env",
              ".env.*",
              ".vscode",
              ".DS_Store",
              "*.pem",
              "*.key",
              "credentials*",
              "secrets*"
            ],
            "description": "Folders and file patterns the Claude Code agent should not access. The agent is instructed to skip these paths.",
            "scope": "resource"
          },
          "ritemark.ai.selectedModel": {
            "type": "string",
            "default": "claude-sonnet-4-5",
            "description": "Claude Code model to use (e.g. claude-sonnet-4-5, claude-opus-4, haiku)",
            "scope": "application"
          },
          "ritemark.ai.hasSeenClaudeWelcome": {
            "type": "boolean",
            "default": false,
            "description": "Internal: tracks whether the Claude Code welcome wizard has been shown.",
            "scope": "application"
          },
          "ritemark.chat.fontSize": {
            "type": "number",
            "default": 13,
            "minimum": 10,
            "maximum": 20,
            "description": "Font size for AI chat interface (10-20px)",
            "scope": "application"
          },
          "ritemark.ai.agentTimeout": {
            "type": "number",
            "default": 15,
            "minimum": 5,
            "maximum": 60,
            "description": "Inactivity timeout for the Claude Code agent in minutes (5-60). The agent will be stopped if it produces no activity for this duration.",
            "scope": "application"
          }
        }
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ritemark-flows",
          "title": "Flows",
          "icon": "media/flows-icon.svg"
        }
      ],
      "auxiliarybar": [
        {
          "id": "ritemark-ai",
          "title": "Ritemark AI",
          "icon": "media/sparkles-icon.svg"
        }
      ]
    },
    "views": {
      "ritemark-ai": [
        {
          "type": "webview",
          "id": "ritemark.unifiedView",
          "name": "Ritemark AI",
          "contextualTitle": "Ritemark AI",
          "visibility": "visible"
        }
      ],
      "ritemark-flows": [
        {
          "type": "webview",
          "id": "ritemark.flowsView",
          "name": "Flows",
          "contextualTitle": "Ritemark Flows",
          "visibility": "visible"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "ritemark.showAIPanel",
          "group": "navigation",
          "when": "activeCustomEditorId == ritemark.editor"
        }
      ],
      "view/title": [
        {
          "command": "ritemark.openSearch",
          "when": "view == workbench.explorer.fileView",
          "group": "navigation@1"
        },
        {
          "command": "ritemark.newChat",
          "when": "view == ritemark.unifiedView",
          "group": "navigation@1"
        },
        {
          "command": "ritemark.chatHistory",
          "when": "view == ritemark.unifiedView",
          "group": "navigation@2"
        },
        {
          "command": "ritemark.aiSettings",
          "when": "view == ritemark.unifiedView",
          "group": "navigation@3"
        },
        {
          "command": "ritemark.flows.new",
          "when": "view == ritemark.flowsView",
          "group": "navigation@1"
        },
        {
          "command": "ritemark.flows.refresh",
          "when": "view == ritemark.flowsView",
          "group": "navigation@2"
        },
        {
          "command": "ritemark.flows.settings",
          "when": "view == ritemark.flowsView",
          "group": "navigation@3"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "ritemark.editor",
        "displayName": "Ritemark",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          },
          {
            "filenamePattern": "*.csv"
          }
        ],
        "priority": "exclusive"
      },
      {
        "viewType": "ritemark.excelViewer",
        "displayName": "Excel Preview",
        "selector": [
          {
            "filenamePattern": "*.xlsx"
          },
          {
            "filenamePattern": "*.xls"
          }
        ],
        "priority": "exclusive"
      },
      {
        "viewType": "ritemark.flowEditor",
        "displayName": "Flow Editor",
        "selector": [
          {
            "filenamePattern": "*.flow.json"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "ritemark.pdfViewer",
        "displayName": "PDF Preview",
        "selector": [
          {
            "filenamePattern": "*.pdf"
          }
        ],
        "priority": "exclusive"
      },
      {
        "viewType": "ritemark.docxViewer",
        "displayName": "DOCX Preview",
        "selector": [
          {
            "filenamePattern": "*.docx"
          }
        ],
        "priority": "exclusive"
      }
    ],
    "configurationDefaults": {
      "files.autoSave": "afterDelay",
      "files.autoSaveDelay": 1000,
      "workbench.sideBar.location": "left",
      "workbench.colorTheme": "ritemark-light",
      "workbench.iconTheme": "ritemark-icons",
      "workbench.activityBar.location": "top",
      "extensions.ignoreRecommendations": true,
      "workbench.tips.enabled": false,
      "debug.showInStatusBar": "never",
      "testing.openTesting": "neverOpen",
      "outline.showVariables": false,
      "outline.showFunctions": false,
      "timeline.showUncommittedChanges": false,
      "window.autoDetectColorScheme": false,
      "workbench.preferredLightColorTheme": "ritemark-light",
      "workbench.preferredDarkColorTheme": "ritemark-light",
      "chat.commandCenter.enabled": false,
      "chat.agent.enabled": false,
      "github.copilot.enable": {
        "*": false
      },
      "github.copilot.editor.enableAutoCompletions": false,
      "github.copilot.editor.enableCodeActions": false,
      "workbench.panel.defaultLocation": "right"
    },
    "themes": [
      {
        "id": "ritemark-light",
        "label": "Ritemark Light",
        "uiTheme": "vs",
        "path": "./themes/ritemark-light.json"
      }
    ],
    "iconThemes": [
      {
        "id": "ritemark-icons",
        "label": "Ritemark Icons",
        "path": "./fileicons/ritemark-icon-theme.json"
      }
    ],
    "keybindings": [
      {
        "key": "cmd+b",
        "command": "-workbench.action.toggleSidebarVisibility",
        "when": "activeCustomEditorId == ritemark.editor"
      },
      {
        "key": "ctrl+b",
        "command": "-workbench.action.toggleSidebarVisibility",
        "when": "activeCustomEditorId == ritemark.editor"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npx tsx src/features/featureGate.test.ts && npx tsx src/flows/flowTypes.test.ts && npx tsx src/flows/FlowExecutor.test.ts && npx tsx src/flows/nodes/ClaudeCodeNodeExecutor.test.ts && npx tsx src/flows/FlowIntegration.test.ts && npx tsx src/flows/nodes/SaveFileNodeExecutor.integration.test.ts && npx tsx src/flows/nodes/ClaudeCodeNodeExecutor.integration.test.ts",
    "test:integration": "npx tsx src/flows/nodes/SaveFileNodeExecutor.integration.test.ts && npx tsx src/flows/nodes/LLMNodeExecutor.integration.test.ts && npx tsx src/flows/nodes/ClaudeCodeNodeExecutor.integration.test.ts",
    "test:integration:free": "npx tsx src/flows/nodes/SaveFileNodeExecutor.integration.test.ts",
    "test:all": "npm run test && npm run test:integration"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.29",
    "@orama/orama": "^3.1.0",
    "@types/marked": "^5.0.2",
    "@types/pdfkit": "^0.17.4",
    "docx": "^8.5.0",
    "gray-matter": "^4.0.3",
    "marked": "^4.3.0",
    "node-html-parser": "^7.0.2",
    "openai": "^6.17.0",
    "papaparse": "^5.5.3",
    "pdfkit": "^0.17.2",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2",
    "xlsx": "^0.18.5",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.8",
    "@types/papaparse": "^5.5.2",
    "@types/turndown": "^5.0.5",
    "@types/vscode": "^1.94.0",
    "lucide-static": "^0.555.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
