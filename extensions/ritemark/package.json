{"name":"ritemark","displayName":"RiteMark Editor","description":"WYSIWYG Markdown Editor","version":"0.1.0","publisher":"ritemark","license":"MIT","engines":{"vscode":"^1.94.0"},"main":"./out/extension.js","activationEvents":["onCustomEditor:ritemark.editor","onView:ritemark.aiView","onCommand:ritemark.configureApiKey","onCommand:ritemark.showAIPanel","onCommand:ritemark.openSearch"],"contributes":{"commands":[{"command":"ritemark.configureApiKey","title":"RiteMark: Configure OpenAI API Key"},{"command":"ritemark.showAIPanel","title":"RiteMark: Show AI Assistant","icon":"$(sparkle)"},{"command":"ritemark.openSearch","title":"Search","icon":"$(search)"}],"viewsContainers":{"auxiliarybar":[{"id":"ritemark-ai","title":"AI Assistant","icon":"$(sparkle)"}]},"views":{"ritemark-ai":[{"type":"webview","id":"ritemark.aiView","name":"AI Assistant","contextualTitle":"RiteMark AI","visibility":"visible"}]},"menus":{"editor/title":[{"command":"ritemark.showAIPanel","group":"navigation","when":"activeCustomEditorId == ritemark.editor"}],"view/title":[{"command":"ritemark.openSearch","when":"view == workbench.explorer.fileView","group":"navigation@1"}]},"customEditors":[{"viewType":"ritemark.editor","displayName":"RiteMark","selector":[{"filenamePattern":"*.md"},{"filenamePattern":"*.markdown"}],"priority":"default"}],"configurationDefaults":{"workbench.sideBar.location":"left","workbench.colorTheme":"Default Light Modern","workbench.iconTheme":"ritemark-icons","workbench.activityBar.location":"default","extensions.ignoreRecommendations":true,"workbench.tips.enabled":false,"debug.showInStatusBar":"never","testing.openTesting":"neverOpen","outline.showVariables":false,"outline.showFunctions":false,"timeline.showUncommittedChanges":false,"window.autoDetectColorScheme":false,"workbench.preferredLightColorTheme":"Default Light Modern","workbench.preferredDarkColorTheme":"Default Light Modern","chat.commandCenter.enabled":false,"chat.agent.enabled":false,"github.copilot.enable":{"*":false},"github.copilot.editor.enableAutoCompletions":false,"github.copilot.editor.enableCodeActions":false},"walkthroughs":[{"id":"ritemark.welcome","title":"Get Started with RiteMark","description":"A beautiful markdown editor with AI assistance","steps":[{"id":"welcome","title":"Welcome to RiteMark","description":"Write in markdown with a clean, distraction-free interface. Your files stay on your computer.","media":{"svg":"media/logo.svg"},"completionEvents":["onStepSelected"]},{"id":"configureApiKey","title":"Configure AI API Key","description":"Optional: Add your OpenAI API key to enable AI writing assistance.\n\n[Configure API Key](command:ritemark.configureApiKey)","completionEvents":["onCommand:ritemark.configureApiKey"]},{"id":"openMarkdown","title":"Open a Markdown File","description":"Open any `.md` file to start writing.\n\n[Open File](command:workbench.action.files.openFileFolder)","completionEvents":["onCommand:workbench.action.files.openFileFolder"]},{"id":"tryAI","title":"Try AI Features","description":"Select text and use the AI panel to rephrase, expand, or improve your writing.\n\n[Show AI Panel](command:ritemark.showAIPanel)","completionEvents":["onCommand:ritemark.showAIPanel"]}]}],"iconThemes":[{"id":"ritemark-icons","label":"RiteMark Icons","path":"./fileicons/ritemark-icon-theme.json"}]},"scripts":{"compile":"tsc -p ./","watch":"tsc -watch -p ./"},"dependencies":{"openai":"^4.73.0","turndown":"^7.2.0","turndown-plugin-gfm":"^1.0.2"},"devDependencies":{"@types/node":"^24.10.1","@types/turndown":"^5.0.5","@types/vscode":"^1.94.0","lucide-static":"^0.555.0","typescript":"^5.0.0"}}