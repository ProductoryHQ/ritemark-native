 				],
-				'default': 'both',
+				'default': 'toggles',
 				'description': localize('layoutControlType', "Controls whether the layout control in the custom title bar is displayed as a single menu button or with multiple UI toggles."),
 			},
 			'workbench.tips.enabled': {
@@ -678,9 +680,10 @@
