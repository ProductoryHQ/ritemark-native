# RiteMark Patch: workbench-explorer-ui
#
# Purpose: Simplify Explorer sidebar - rename to "Project", keep only New File/Folder buttons,
#          remove tree indent guides, add rounded selection highlight with inset spacing
#
# Why: Cleaner, more focused file browser matching Ritemark's design language
#
# File(s): explorerViewlet.ts, explorerView.ts, explorerviewlet.css
# Created: 2026-02-13
#
diff --git a/src/vs/workbench/contrib/files/browser/explorerViewlet.ts b/src/vs/workbench/contrib/files/browser/explorerViewlet.ts
