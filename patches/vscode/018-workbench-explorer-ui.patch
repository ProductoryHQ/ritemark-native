+++ b/src/vs/workbench/contrib/files/browser/explorerViewlet.ts
@@ -255,7 +255,7 @@ const viewContainerRegistry = Registry.as<IViewContainersRegistry>(Extensions.Vi
  */
 export const VIEW_CONTAINER: ViewContainer = viewContainerRegistry.registerViewContainer({
 	id: VIEWLET_ID,
-	title: localize2('explore', "Explorer"),
+	title: localize2('explore', "Project"),
 	ctorDescriptor: new SyncDescriptor(ExplorerViewPaneContainer),
 	storageId: 'workbench.explorer.views.state',
 	icon: explorerViewIcon,
@@ -264,8 +264,8 @@ export const VIEW_CONTAINER: ViewContainer = viewContainerRegistry.registerViewC
 	order: 0,
 	openCommandActionDescriptor: {
 		id: VIEWLET_ID,
-		title: localize2('explore', "Explorer"),
-		mnemonicTitle: localize({ key: 'miViewExplorer', comment: ['&& denotes a mnemonic'] }, "&&Explorer"),
+		title: localize2('explore', "Project"),
+		mnemonicTitle: localize({ key: 'miViewExplorer', comment: ['&& denotes a mnemonic'] }, "&&Project"),
 		keybindings: { primary: KeyMod.CtrlCmd | KeyMod.Shift | KeyCode.KeyE },
 		order: 0
 	},
diff --git a/src/vs/workbench/contrib/files/browser/media/explorerviewlet.css b/src/vs/workbench/contrib/files/browser/media/explorerviewlet.css
index 7a3237b22f5..a263a487cfb 100644
--- a/src/vs/workbench/contrib/files/browser/media/explorerviewlet.css
+++ b/src/vs/workbench/contrib/files/browser/media/explorerviewlet.css
@@ -101,3 +101,38 @@
 .monaco-workbench.context-menu-visible .explorer-folders-view.highlight .monaco-list-row {
 	outline: none !important;
 }
+
+/* --- Ritemark: Hide tree indent guide lines --- */
+.explorer-folders-view .monaco-tl-indent > .indent-guide {
+	border-color: transparent !important;
+}
+
+/* --- Ritemark: Kill ALL outer row backgrounds in explorer --- */
+.explorer-folders-view .monaco-list .monaco-list-row {
+	background-color: transparent !important;
+	outline: none !important;
+}
+
+/* --- Ritemark: Inner row gets inset + rounded corners --- */
+.explorer-folders-view .monaco-list .monaco-tl-row {
+	border-radius: 6px;
+	margin: 0 20px 0 4px;
+}
+
+/* --- Ritemark: Rounded highlight on inner row for each state --- */
+.explorer-folders-view .monaco-list:focus .monaco-list-row.selected .monaco-tl-row,
+.explorer-folders-view .monaco-list:focus .monaco-list-row.selected.focused .monaco-tl-row {
+	background-color: var(--vscode-list-activeSelectionBackground);
+}
+
+.explorer-folders-view .monaco-list:focus .monaco-list-row.focused:not(.selected) .monaco-tl-row {
+	background-color: var(--vscode-list-focusBackground);
+}
+
+.explorer-folders-view .monaco-list .monaco-list-row.selected .monaco-tl-row {
+	background-color: var(--vscode-list-inactiveSelectionBackground);
+}
+
+.explorer-folders-view .monaco-list:not(.drop-target):not(.dragging) .monaco-list-row:hover .monaco-tl-row {
+	background-color: var(--vscode-list-hoverBackground);
+}
