Ritemark Windows & OSS Fixes: Productory branding in build system, Windows manifests
Sprint 39: Electron/rcedit company name, copyright, server manifest
Note: VisualElementsManifest.xml is handled by apply-patches.sh (CRLF file)
---
diff --git a/build/gulpfile.vscode.js b/build/gulpfile.vscode.js
--- a/build/gulpfile.vscode.js
+++ b/build/gulpfile.vscode.js
@@ -519,11 +519,11 @@
 			await rcedit(path.join(cwd, dep), {
 				'file-version': baseVersion,
 				'version-string': {
-					'CompanyName': 'Microsoft Corporation',
+					'CompanyName': 'Productory',
 					'FileDescription': product.nameLong,
 					'FileVersion': packageJson.version,
 					'InternalName': basename,
-					'LegalCopyright': 'Copyright (C) 2022 Microsoft. All rights reserved',
+					'LegalCopyright': 'Copyright (C) 2026 Productory. All rights reserved',
 					'OriginalFilename': basename,
 					'ProductName': product.nameLong,
 					'ProductVersion': packageJson.version,
diff --git a/build/lib/electron.ts b/build/lib/electron.ts
--- a/build/lib/electron.ts
+++ b/build/lib/electron.ts
@@ -103,8 +103,8 @@
 	version: electronVersion,
 	tag: product.electronRepository ? `v${electronVersion}-${msBuildId}` : undefined,
 	productAppName: product.nameLong,
