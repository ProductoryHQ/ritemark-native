+	user: { id: 'lucide-user' } as ThemeIcon,
+	sparkle: { id: 'lucide-sparkle' } as ThemeIcon,
+	bookOpen: { id: 'lucide-bookOpen' } as ThemeIcon,
+	fileOutput: { id: 'lucide-fileOutput' } as ThemeIcon,
