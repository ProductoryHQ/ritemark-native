+// RiteMark: Lucide icon font registration
+const LucideIcons = {
+	folder: 0xe0d7, folderOpen: 0xe247, files: 0xe0cf, file: 0xe0c0,
+	fileText: 0xe0cc, search: 0xe151, gitBranch: 0xe0e2, settings: 0xe154,
+	user: 0xe19f, sparkle: 0xe47e, bookOpen: 0xe05f, fileOutput: 0xe0c8,
+	terminal: 0xe181, triangleAlert: 0xe193, clock: 0xe087, list: 0xe106,
+} as const;
+
+const lucideFontDefinition: IconFontDefinition = {
+	src: [{ location: URI.parse('lucide.woff2'), format: 'woff2' }]
+};
+iconRegistry.registerIconFont('lucide', lucideFontDefinition);
+
+const lucideFont: IconFontContribution = { id: 'lucide', definition: lucideFontDefinition };
+for (const [name, code] of Object.entries(LucideIcons)) {
+	const fontCharacter = '\\' + code.toString(16);
+	iconRegistry.registerIcon(`lucide-${name}`, { font: lucideFont, fontCharacter });
+}
+
