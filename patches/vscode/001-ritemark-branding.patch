diff --git a/src/vs/workbench/contrib/welcomeGettingStarted/browser/media/gettingStartedGuide.css b/src/vs/workbench/contrib/welcomeGettingStarted/browser/media/gettingStartedGuide.css
new file mode 100644
index 00000000000..68e0c33e429
--- /dev/null
+++ b/src/vs/workbench/contrib/welcomeGettingStarted/browser/media/gettingStartedGuide.css
@@ -0,0 +1,193 @@
+/*---------------------------------------------------------------------------------------------
+ *  RiteMark Welcome Page Guide Styling
+ *  Copyright (c) Productory. All rights reserved.
+ *--------------------------------------------------------------------------------------------*/
+
+/* Brand color variables */
+:root {
+	--productory-indigo: #5046E5;
+	--productory-cyan: #06B6D4;
+	--productory-magenta: #EC4899;
+	--productory-indigo-light: #6366F1;
+	--productory-gradient: linear-gradient(135deg, var(--productory-indigo), var(--productory-cyan));
+}
+
+/* ========================================
+   RiteMark Welcome Page - Guide Section
+   ======================================== */
+
+/* Centered single-column layout for guides */
+.monaco-workbench .part.editor > .content .gettingStartedContainer .gettingStartedSlideCategories > .gettingStartedCategoriesContainer > .categories-column-center {
+	display: flex;
+	flex-direction: column;
+	align-items: center;
+	justify-content: flex-start;
+	padding: 0 16px;
+}
+
+/* Guide container */
+.monaco-workbench .part.editor > .content .gettingStartedContainer .guide-container {
+	max-width: 480px;
+	width: 100%;
+	margin: 0 auto;
+}
+
+/* Guide step styling */
+.monaco-workbench .part.editor > .content .gettingStartedContainer .guide-step {
+	display: flex;
+	align-items: flex-start;
+	padding: 16px 0;
+	border-bottom: 1px solid var(--vscode-widget-border, rgba(0, 0, 0, 0.08));
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .guide-step:last-child {
+	border-bottom: none;
+}
+
+/* Step number */
+.monaco-workbench .part.editor > .content .gettingStartedContainer .guide-step .step-number {
+	flex-shrink: 0;
+	width: 32px;
+	height: 32px;
+	border-radius: 50%;
+	background: var(--productory-gradient);
+	color: #FFFFFF;
+	font-weight: 600;
+	font-size: 14px;
+	display: flex;
+	align-items: center;
+	justify-content: center;
+	margin-right: 16px;
+	margin-top: 2px;
+}
+
+/* Step content */
+.monaco-workbench .part.editor > .content .gettingStartedContainer .guide-step .step-content {
+	flex: 1;
+	min-width: 0;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .guide-step .step-content h3 {
+	margin: 0 0 4px 0;
+	font-size: 14px;
+	font-weight: 600;
+	line-height: 1.4;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .guide-step .step-content p {
+	margin: 0;
+	font-size: 13px;
+	line-height: 1.5;
+	color: var(--vscode-descriptionForeground);
+}
+
+/* Step action link */
+.monaco-workbench .part.editor > .content .gettingStartedContainer .guide-step .step-action {
+	display: inline-block;
+	margin-top: 8px;
+	color: var(--productory-indigo);
+	font-size: 13px;
+	font-weight: 500;
+	cursor: pointer;
+	text-decoration: none;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .guide-step .step-action:hover {
+	color: var(--productory-indigo-light);
+	text-decoration: underline;
+}
+
+/* ========================================
+   Footer styling
+   ======================================== */
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .gettingStartedSlideCategories > .gettingStartedCategoriesContainer > .footer {
+	padding: 16px 0;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .gettingStartedSlideCategories > .gettingStartedCategoriesContainer > .footer p {
+	font-size: 12px;
+	color: var(--vscode-descriptionForeground);
+}
+
+/* ========================================
+   Hide default walkthroughs (optional override)
+   ======================================== */
+
+/* Link styling with brand colors */
+.monaco-workbench .part.editor > .content .gettingStartedContainer .guide-link {
+	color: var(--productory-indigo);
+	text-decoration: none;
+	font-weight: 500;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .guide-link:hover {
+	color: var(--productory-indigo-light);
+	text-decoration: underline;
+}
+
+/* ========================================
+   Header / Logo styling
+   ======================================== */
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .gettingStartedSlideCategories > .gettingStartedCategoriesContainer > .header {
+	display: flex;
+	flex-direction: column;
+	align-items: center;
+	justify-content: flex-end;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .gettingStartedSlideCategories > .gettingStartedCategoriesContainer > .header .welcome-logo {
+	width: 64px;
+	height: 64px;
+	margin-bottom: 16px;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .gettingStartedSlideCategories > .gettingStartedCategoriesContainer > .header h1 {
+	text-align: center;
+	white-space: normal;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .gettingStartedSlideCategories > .gettingStartedCategoriesContainer > .header .subtitle {
+	text-align: center;
+}
+
+/* ========================================
+   Responsive adjustments
+   ======================================== */
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer.width-constrained .gettingStartedSlideCategories > .gettingStartedCategoriesContainer {
+	grid-template-rows: auto min-content minmax(min-content, auto) min-content min-content;
+	grid-template-columns: 1fr;
+	grid-template-areas: "header" "left-column" "center-column" "right-column" "footer";
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer.height-constrained .gettingStartedSlideCategories > .gettingStartedCategoriesContainer {
+	grid-template-rows: auto minmax(min-content, auto) min-content;
+	grid-template-areas: "header" "left-column center-column right-column" "footer footer footer";
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer.height-constrained.width-constrained .gettingStartedSlideCategories > .gettingStartedCategoriesContainer {
+	grid-template-rows: min-content minmax(min-content, auto) min-content min-content;
+	grid-template-columns: 1fr;
+	grid-template-areas: "left-column" "center-column" "right-column" "footer";
+}
+
+/* ========================================
+   Brand accent on walkthrough cards
+   ======================================== */
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .gettingStartedSlideCategories .getting-started-category:hover {
+	border-color: var(--productory-indigo, var(--vscode-focusBorder));
+}
+
+/* Guide step completed state */
+.monaco-workbench .part.editor > .content .gettingStartedContainer .guide-step.completed .step-number {
+	background: var(--vscode-textLink-foreground);
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .guide-step.completed .step-number::after {
+	content: var(--vscode-icon-check-content, "\eab2");
+	font-family: codicon;
+	font-size: 16px;
+}
