# RiteMark Patch: workbench-font-and-typography-base
#
# Purpose: Bundle Sofia Sans font locally and apply as default UI font across all platforms.
#          Remove Google Fonts network dependency. Wire font files into production build pipeline.
#
# Why: Ritemark branding requires Sofia Sans as UI font. Network fonts are unreliable
#      and violate local-first principle. Build pipeline needs .woff2 support for production.
#
# Files: src/vs/workbench/browser/media/style.css,
#        src/vs/workbench/browser/media/fonts/SofiaSans-latin.woff2,
#        src/vs/workbench/browser/media/fonts/SofiaSans-latin-ext.woff2,
#        src/vs/workbench/contrib/welcomeGettingStarted/browser/media/gettingStartedGuide.css,
#        build/lib/optimize.ts,
#        build/gulpfile.vscode.js
# Created: 2026-02-13
#
diff --git a/build/gulpfile.vscode.js b/build/gulpfile.vscode.js
index 9dfb6a3848c..c1772b612fc 100644
--- a/build/gulpfile.vscode.js
+++ b/build/gulpfile.vscode.js
@@ -94,6 +94,10 @@ const vscodeResourceIncludes = !isAMD() ? [
 	// Accessibility Signals
 	'out-build/vs/platform/accessibilitySignal/browser/media/*.mp3',
 
+	// Ritemark UI fonts (Sofia Sans)
+	'out-build/media/*.woff2',
+	'out-build/vs/workbench/browser/media/fonts/*.woff2',
+
 	// Welcome
 	'out-build/vs/workbench/contrib/welcomeGettingStarted/common/media/**/*.{svg,png}',
 
@@ -128,6 +132,8 @@ const vscodeResourceIncludes = !isAMD() ? [
 	'out-build/vs/base/parts/sandbox/electron-sandbox/preload.js',
 	'out-build/vs/base/parts/sandbox/electron-sandbox/preload-aux.js',
 	'out-build/vs/workbench/browser/media/*-theme.css',
+	'out-build/media/*.woff2',
+	'out-build/vs/workbench/browser/media/fonts/*.woff2',
 	'out-build/vs/workbench/contrib/debug/**/*.json',
 	'out-build/vs/workbench/contrib/externalTerminal/**/*.scpt',
 	'out-build/vs/workbench/contrib/terminal/common/scripts/fish_xdg_data/fish/vendor_conf.d/*.fish',
diff --git a/build/lib/optimize.ts b/build/lib/optimize.ts
