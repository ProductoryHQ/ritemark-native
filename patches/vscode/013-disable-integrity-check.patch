#
# Purpose: Skip VS Code installation integrity/checksum verification
#
# Why: VS Code forks always fail integrity checks because files are modified.
#      This causes a false "corrupt installation" warning on every launch.
#      Standard practice for VS Code forks (VSCodium does the same).
#
# File(s): src/vs/workbench/services/integrity/electron-sandbox/integrityService.ts
# Created: 2025-02-07
#
