+/* ============================================
+   RiteMark Welcome Page - Landing Page Layout
+   Productory Brand Guidelines Applied
+   ============================================ */
+
+/* ----------------------------------------
+   Brand Color Variables
+   ---------------------------------------- */
+.monaco-workbench .part.editor > .content .gettingStartedContainer {
+	--productory-indigo: #4338ca;
+	--productory-cyan: #2dd4bf;
+	--productory-magenta: #d946ef;
+	--productory-deep-space: #1e1b4b;
+	--productory-slate-900: #0f172a;
+	--productory-slate-600: #475569;
+	--productory-slate-100: #f1f5f9;
+}
+
+/* ----------------------------------------
+   Base Typography
+   ---------------------------------------- */
+.monaco-workbench .part.editor > .content .gettingStartedContainer {
+	font-family: var(--ritemark-ui-font-family, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif) !important;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer h1,
+.monaco-workbench .part.editor > .content .gettingStartedContainer h2,
+.monaco-workbench .part.editor > .content .gettingStartedContainer h3 {
+	font-family: var(--ritemark-ui-font-family, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif) !important;
+}
+
+/* ----------------------------------------
+   Layout - Centered Single Column
+   ---------------------------------------- */
+
+/* Override default 3-column grid to centered single column */
+.monaco-workbench .part.editor > .content .gettingStartedContainer .gettingStartedSlideCategories > .gettingStartedCategoriesContainer {
+	display: flex !important;
+	flex-direction: column !important;
+	align-items: center !important;
+	max-width: 680px !important;
+	margin: 0 auto !important;
+	padding: 48px 32px 32px !important;
+	gap: 0 !important;
+}
+
+/* Hero Section - Logo & Tagline */
+.monaco-workbench .part.editor > .content .gettingStartedContainer .gettingStartedSlideCategories > .gettingStartedCategoriesContainer > .header {
+	display: flex !important;
+	flex-direction: column;
+	align-items: flex-start !important;
+	text-align: left !important;
+	margin-bottom: 48px !important;
+	padding-top: 24px;
+	width: 100%;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .header .ritemark-logo {
+	width: 240px !important;
+	height: auto;
+	margin-bottom: 16px !important;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .header .subtitle {
+	font-size: 1.5em !important;
+	font-weight: 400;
+	color: var(--vscode-foreground);
+	opacity: 0.85;
+	margin: 0;
+	letter-spacing: -0.01em;
+}
+
+/* Main Content Columns - Stack Vertically */
+.monaco-workbench .part.editor > .content .gettingStartedContainer .gettingStartedSlideCategories > .gettingStartedCategoriesContainer > .categories-column {
+	width: 100% !important;
+	max-width: 100% !important;
+	margin-bottom: 32px;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .gettingStartedSlideCategories > .gettingStartedCategoriesContainer > .categories-column-left {
+	order: 1;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .gettingStartedSlideCategories > .gettingStartedCategoriesContainer > .categories-column-center {
+	order: 2;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .gettingStartedSlideCategories > .gettingStartedCategoriesContainer > .categories-column-right {
+	order: 3;
+}
+
+/* Section Headers */
+.monaco-workbench .part.editor > .content .gettingStartedContainer .index-list h2,
+.monaco-workbench .part.editor > .content .gettingStartedContainer .getting-started-guide h2 {
+	font-size: 14px !important;
+	font-weight: 600 !important;
+	text-transform: uppercase;
+	letter-spacing: 0.05em;
+	color: var(--vscode-descriptionForeground);
+	margin-bottom: 16px !important;
+	padding-bottom: 8px;
+	border-bottom: 1px solid var(--vscode-widget-border, rgba(0,0,0,0.1));
+}
+
+/* Start & Recent Lists - Horizontal Layout */
+.monaco-workbench .part.editor > .content .gettingStartedContainer .index-list ul {
+	display: flex;
+	flex-wrap: wrap;
+	gap: 8px 24px;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .index-list li {
+	white-space: nowrap;
+}
+
+/* Guide Steps Container */
+.monaco-workbench .part.editor > .content .gettingStartedContainer .getting-started-guide {
+	width: 100%;
+	margin-top: 8px;
+}
+
+/* Guide Steps Styling */
+.monaco-workbench .part.editor > .content .gettingStartedContainer .getting-started-guide-step {
+	display: flex;
+	margin-bottom: 28px;
+	align-items: flex-start;
+	padding: 16px 20px;
+	background: var(--vscode-welcomePage-tileBackground, rgba(0,0,0,0.03));
+	border-radius: 8px;
+	transition: background 0.15s ease;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .getting-started-guide-step:hover {
+	background: var(--vscode-welcomePage-tileHoverBackground, rgba(0,0,0,0.05));
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .getting-started-guide-step .step-number {
+	font-family: var(--ritemark-ui-font-family, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif);
+	font-size: 36px;
+	font-weight: bold;
+	line-height: 1;
+	margin-right: 20px;
+	min-width: 32px;
+}
+
+/* Step Number Colors - Productory Brand */
+.monaco-workbench .part.editor > .content .gettingStartedContainer .getting-started-guide-step:nth-child(2) .step-number {
+	color: #4338ca; /* Productory Indigo */
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .getting-started-guide-step:nth-child(3) .step-number {
+	color: #2dd4bf; /* Electric Cyan */
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .getting-started-guide-step:nth-child(4) .step-number {
+	color: #d946ef; /* Magenta Ray */
+}
+
+/* High Contrast Mode Override */
+.monaco-workbench.hc-black .part.editor > .content .gettingStartedContainer .getting-started-guide-step .step-number,
+.monaco-workbench.hc-light .part.editor > .content .gettingStartedContainer .getting-started-guide-step .step-number {
+	color: var(--vscode-foreground) !important;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .getting-started-guide-step .step-content {
+	flex: 1;
+	padding-top: 4px;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .getting-started-guide-step h3 {
+	font-size: 15px;
+	font-weight: 600;
+	margin: 0 0 6px 0;
+	color: var(--vscode-foreground);
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .getting-started-guide-step p {
+	font-size: 13px;
+	margin: 0 0 12px 0;
+	color: var(--vscode-descriptionForeground);
+	line-height: 1.5;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .getting-started-guide-step .button-link {
+	font-size: 13px;
+	font-weight: 500;
+}
+
+/* Footer - Checkbox */
+.monaco-workbench .part.editor > .content .gettingStartedContainer .gettingStartedSlideCategories > .gettingStartedCategoriesContainer > .footer {
+	order: 4;
+	width: 100%;
+	margin-top: 24px;
+	padding-top: 24px;
+	border-top: 1px solid var(--vscode-widget-border, rgba(0,0,0,0.1));
+}
+
+/* Hide walkthroughs section if empty - keep layout clean */
+.monaco-workbench .part.editor > .content .gettingStartedContainer.noWalkthroughs .categories-column-right .index-list.getting-started {
+	display: none;
+}
+
+/* ----------------------------------------
+   Link Colors - Productory Indigo
+   ---------------------------------------- */
+.monaco-workbench .part.editor > .content .gettingStartedContainer a:not(.hide-category-button),
+.monaco-workbench .part.editor > .content .gettingStartedContainer .button-link {
+	color: var(--productory-indigo, #4338ca) !important;
+	text-decoration: none;
+	font-weight: 500;
+	transition: color 150ms ease;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer a:not(.hide-category-button):hover,
+.monaco-workbench .part.editor > .content .gettingStartedContainer .button-link:hover {
+	color: #3730a3 !important; /* Darker indigo on hover */
+}
+
+/* ----------------------------------------
+   Button Styling - Productory Brand
+   ---------------------------------------- */
+
+/* Primary Action Buttons in Guide Steps */
+.monaco-workbench .part.editor > .content .gettingStartedContainer .getting-started-guide-step .button-link {
+	display: inline-flex;
+	align-items: center;
+	padding: 8px 16px;
+	background: var(--productory-indigo, #4338ca);
+	color: white !important;
+	border-radius: 8px;
+	font-weight: 600;
+	font-size: 13px;
+	box-shadow: 0 4px 6px -1px rgba(67, 56, 202, 0.25);
+	transition: all 150ms ease;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .getting-started-guide-step .button-link:hover {
+	background: #3730a3;
+	color: white !important;
+	transform: translateY(-1px);
+	box-shadow: 0 6px 8px -1px rgba(67, 56, 202, 0.3);
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .getting-started-guide-step .button-link:active {
+	transform: scale(0.98);
+}
+
+/* Start Menu Buttons - Ghost Style */
+.monaco-workbench .part.editor > .content .gettingStartedContainer .start-container .button-link {
+	display: inline-flex;
+	align-items: center;
+	gap: 8px;
+	padding: 10px 16px;
+	background: transparent;
+	border: 2px solid var(--productory-indigo, #4338ca);
+	color: var(--productory-indigo, #4338ca) !important;
+	border-radius: 8px;
+	font-weight: 600;
+	transition: all 150ms ease;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .start-container .button-link:hover {
+	background: var(--productory-indigo, #4338ca);
+	color: white !important;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .start-container .button-link:hover .codicon,
+.monaco-workbench .part.editor > .content .gettingStartedContainer .start-container .button-link:hover .icon-widget {
+	color: white !important;
+}
+
+/* ----------------------------------------
+   Checkbox Styling - Brand Colors
+   ---------------------------------------- */
+.monaco-workbench .part.editor > .content .gettingStartedContainer .getting-started-checkbox {
+	background-color: white !important;
+	border: 2px solid #cbd5e1 !important;
+	border-radius: 6px !important;
+	transition: all 150ms ease;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .getting-started-checkbox:hover {
+	border-color: rgba(67, 56, 202, 0.5) !important;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .getting-started-checkbox.checked {
+	background-color: var(--productory-indigo, #4338ca) !important;
+	border-color: var(--productory-indigo, #4338ca) !important;
+}
+
+/* ----------------------------------------
+   Hide Get Started Section
+   ---------------------------------------- */
+.monaco-workbench .part.editor > .content .gettingStartedContainer .getting-started-guide {
+	display: none !important;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .categories-column-right {
+	display: none !important;
+}
+
+/* ----------------------------------------
+   Section Headers - Brand Styling
+   ---------------------------------------- */
+.monaco-workbench .part.editor > .content .gettingStartedContainer .index-list h2,
+.monaco-workbench .part.editor > .content .gettingStartedContainer .getting-started-guide h2 {
+	font-family: var(--ritemark-ui-font-family, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif) !important;
+	color: var(--productory-slate-600, #475569) !important;
+}
+
+/* ----------------------------------------
+   Recent List Styling
+   ---------------------------------------- */
+.monaco-workbench .part.editor > .content .gettingStartedContainer .recent-list li {
+	padding: 6px 0;
+}
+
+.monaco-workbench .part.editor > .content .gettingStartedContainer .recent-list .path {
+	color: var(--productory-slate-600, #475569);
+	font-size: 12px;
+	opacity: 0.8;
+}
+
+/* ----------------------------------------
+   Focus States - Accessibility
+   ---------------------------------------- */
+.monaco-workbench .part.editor > .content .gettingStartedContainer a:focus-visible,
+.monaco-workbench .part.editor > .content .gettingStartedContainer button:focus-visible {
+	outline: none;
+	box-shadow: 0 0 0 4px rgba(67, 56, 202, 0.15);
+	border-radius: 4px;
+}
+
+/* ----------------------------------------
+   Icon Colors
+   ---------------------------------------- */
+.monaco-workbench .part.editor > .content .gettingStartedContainer .icon-widget {
+	color: var(--productory-indigo, #4338ca) !important;
+}
