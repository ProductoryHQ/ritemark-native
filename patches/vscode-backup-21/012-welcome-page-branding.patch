+	private buildGuideList(): HTMLElement {
+		const container = $('.getting-started-guide');
+		
+		const steps = [
+			{
+				title: localize('guide.step1.title', "Create a Project"),
+				description: localize('guide.step1.desc', "Open a folder to organize your markdown files."),
+				button: { label: localize('guide.step1.btn', "Open Folder"), command: 'openFolder' }
+			},
+			{
+				title: localize('guide.step2.title', "Add Content"),
+				description: localize('guide.step2.desc', "Create a new file to start writing."),
+				button: { label: localize('guide.step2.btn', "New File"), command: 'selectStartEntry:welcome.showNewFileEntries' }
+			},
+			{
+				title: localize('guide.step3.title', "Write with AI"),
+				description: localize('guide.step3.desc', "Use the AI assistant to generate or edit text."),
+				// No button for this one maybe, or a link to documentation?
+			}
+		];
+
+		// Title for the section
+		const title = $('h2', {}, localize('guide.title', "Get Started"));
+		container.appendChild(title);
+
+		steps.forEach((step, index) => {
+			const stepContent = $('div.step-content', {},
+				$('h3', {}, step.title),
+				$('p', {}, step.description)
+			);
+			if (step.button) {
+				stepContent.appendChild($('button.button-link', { 'x-dispatch': step.button.command }, step.button.label));
+			}
+			const stepEl = $('.getting-started-guide-step', {},
+				$('div.step-number', {}, (index + 1).toString()),
+				stepContent
+			);
+			container.appendChild(stepEl);
+		});
+
+		return container;
 	}
 
 	private buildStartList(): GettingStartedIndexList<IWelcomePageStartEntry> {
