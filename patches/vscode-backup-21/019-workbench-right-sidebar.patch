# RiteMark Patch: Right Sidebar - Auxiliary Bar Extension Containers
#
# Purpose: Keep extension-contributed auxiliary bar view containers always visible
#          (hideIfEmpty: false) so they persist in the tab strip alongside Terminal.
#
# Why: Without this, extension containers (like Ritemark AI) use hideIfEmpty: true
#      by default. This causes the Terminal tab to lose its pinned state and vanish
#      from the tab strip when switching between containers.
#
# File(s): src/vs/workbench/api/browser/viewsExtensionPoint.ts
# Created: 2026-02-13
#
diff --git a/src/vs/workbench/api/browser/viewsExtensionPoint.ts b/src/vs/workbench/api/browser/viewsExtensionPoint.ts
index f0171ad8677..2629f88ffa5 100644
--- a/src/vs/workbench/api/browser/viewsExtensionPoint.ts
+++ b/src/vs/workbench/api/browser/viewsExtensionPoint.ts
@@ -411,7 +411,7 @@ class ViewsExtensionHandler implements IWorkbenchContribution {
 					ViewPaneContainer,
 					[id, { mergeViewWithContainerWhenSingleView: true }]
 				),
-				hideIfEmpty: true,
+				hideIfEmpty: location !== ViewContainerLocation.AuxiliaryBar, /* Ritemark: keep auxiliary bar containers always visible */
 				order,
 				icon,
 			}, location);
